{ 
   "$schema": "https://turbo.build/schema.json", 
   "ui": "tui",
   "tasks":{
      "build":{  
         "dependsOn": ["^build"],  
         "outputs": ["dist/**", ".next/**", "build/**"]
      }, 
      "dev":{
         "cache":false,
         "persistent":true   
      },
      "lint": {   
         "dependsOn": ["^build"]   
      },
      "check-types": {
         "dependsOn": ["^build"]   
      }   
   }   
}  